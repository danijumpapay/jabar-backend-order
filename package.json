{
  "name": "jabar-backend-order",
  "version": "1.0.0",
  "description": "REST API Backend for Jabar",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node -r tsconfig-paths/register index.ts",
    "build": "npx tsc && tsc-alias",
    "prod:start": "node dist/index.js",
    "migrate": "npx knex migrate:latest --env development --knexfile knexfile.ts",
    "migrate:rollback": "npx knex migrate:rollback --env development --knexfile knexfile.ts",
    "migrate:make": "npx knex migrate:make %npm_config_name% --env development --knexfile knexfile.ts -x ts"
  },
  "author": "danixsofyan",
  "license": "ISC",
  "dependencies": {
    "@jumpapay/jumpapay-models": "^8.3.0",
    "axios": "^1.9.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "joi": "^17.9.2",
    "jsonwebtoken": "^9.0.0",
    "knex": "3.1.0",
    "lodash": "^4.17.23",
    "multer": "^1.4.5-lts.1",
    "node-cache": "^5.1.2",
    "objection": "3.1.4",
    "pg": "^8.10.0",
    "pino": "^10.1.1",
    "qs": "^6.15.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/lodash": "^4.17.24",
    "@types/multer": "^1.4.12",
    "@types/node": "^18.15.11",
    "@types/qs": "^6.14.0",
    "@types/uuid": "^10.0.0",
    "ts-node": "^10.9.1",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.0.4"
  }
}