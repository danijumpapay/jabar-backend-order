{
    "info": {
        "name": "Jabar Backend Order API",
        "_postman_id": "jabar-backend-order-v1",
        "description": "REST API for jabar-backend-order management. Base URL: http://localhost:3001",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        {
            "key": "base_url",
            "value": "http://localhost:3001",
            "type": "string"
        },
        {
            "key": "order_id",
            "value": "",
            "type": "string",
            "description": "UUID orderId from POST /orders response"
        },
        {
            "key": "booking_id",
            "value": "",
            "type": "string",
            "description": "bookingId from POST /orders response (e.g. KPyyyyMMddXXXX)"
        }
    ],
    "item": [
        {
            "name": "Health Check",
            "request": {
                "method": "GET",
                "header": [],
                "url": {
                    "raw": "{{base_url}}/",
                    "host": [
                        "{{base_url}}"
                    ],
                    "path": [
                        ""
                    ]
                },
                "description": "Check if the server is running"
            }
        },
        {
            "name": "Vehicle",
            "item": [
                {
                    "name": "Check Vehicle Info",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"plat\": \"D1234ABC\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{base_url}}/api/v1/vehicle/check",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "v1",
                                "vehicle",
                                "check"
                            ]
                        },
                        "description": "Proxy to Sambara API to check vehicle tax info"
                    }
                }
            ]
        },
        {
            "name": "Vouchers",
            "item": [
                {
                    "name": "Validate Voucher",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"code\": \"KANGPAJAK10\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{base_url}}/api/v1/vouchers/validate",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "v1",
                                "vouchers",
                                "validate"
                            ]
                        },
                        "description": "Check if a voucher code is valid"
                    }
                }
            ]
        },
        {
            "name": "Services",
            "item": [
                {
                    "name": "List Available Services",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{base_url}}/api/v1/services",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "v1",
                                "services"
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "Promos",
            "item": [
                {
                    "name": "List Active Promos",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{base_url}}/api/v1/promos",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "v1",
                                "promos"
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "Orders",
            "item": [
                {
                    "name": "Create New Order",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "var json = pm.response.json();",
                                    "if (json.success && json.results) {",
                                    "  pm.collectionVariables.set('order_id', json.results.orderId);",
                                    "  pm.collectionVariables.set('booking_id', json.results.bookingId);",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"name\": \"Budi Santoso\",\n  \"email\": \"budi@email.com\",\n  \"phoneNumber\": \"081234567890\",\n  \"identityNumber\": \"3201234567890001\",\n  \"plateNumber\": \"D1234ABC\",\n  \"chassisNumber\": \"MHFXX123456789\",\n  \"serviceId\": \"1\",\n  \"deliveryFee\": 50000,\n  \"totalAmount\": 350000,\n  \"address\": \"Jl. Sudirman No.1, Bandung\",\n  \"city\": \"Bandung\",\n  \"paymentMethod\": \"BRI\",\n  \"voucherCode\": \"\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{base_url}}/api/v1/orders",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "v1",
                                "orders"
                            ]
                        }
                    }
                },
                {
                    "name": "Track Order (by bookingId)",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{base_url}}/api/v1/orders/{{booking_id}}",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "v1",
                                "orders",
                                "{{booking_id}}"
                            ]
                        }
                    }
                },
                {
                    "name": "Check Payment Status",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{base_url}}/api/v1/orders/{{order_id}}/payment-status",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "v1",
                                "orders",
                                "{{order_id}}",
                                "payment-status"
                            ]
                        }
                    }
                },
                {
                    "name": "Upload Documents",
                    "request": {
                        "method": "POST",
                        "header": [],
                        "body": {
                            "mode": "formdata",
                            "formdata": [
                                {
                                    "key": "ktp",
                                    "type": "file",
                                    "src": ""
                                },
                                {
                                    "key": "stnk",
                                    "type": "file",
                                    "src": ""
                                },
                                {
                                    "key": "bpkb",
                                    "type": "file",
                                    "src": ""
                                }
                            ]
                        },
                        "url": {
                            "raw": "{{base_url}}/api/v1/orders/{{order_id}}/documents",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "v1",
                                "orders",
                                "{{order_id}}",
                                "documents"
                            ]
                        }
                    }
                },
                {
                    "name": "Cancel Order",
                    "request": {
                        "method": "PATCH",
                        "header": [],
                        "url": {
                            "raw": "{{base_url}}/api/v1/orders/{{order_id}}/cancel",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "v1",
                                "orders",
                                "{{order_id}}",
                                "cancel"
                            ]
                        }
                    }
                },
                {
                    "name": "Request Refund",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"actualAmount\": 350000,\n  \"bank\": \"BRI\",\n  \"accountNumber\": \"1234567890\",\n  \"notes\": \"Incorrect service selected\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{base_url}}/api/v1/orders/{{order_id}}/refund",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "v1",
                                "orders",
                                "{{order_id}}",
                                "refund"
                            ]
                        }
                    }
                }
            ]
        }
    ]
}